{
  "name": "@mrnine/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript wrapper cho MrNine API gateway (https://api.mrnine.net)",
  "license": "MIT",
  "author": "MrNine <hello@mrnine.net>",
  "homepage": "https://mrnine.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguy3nhuunam/MrNine.Net",
    "directory": "sdk"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
